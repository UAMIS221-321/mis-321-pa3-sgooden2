<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>MovieNight</RootNamespace>
    <AssemblyName>MovieNight</AssemblyName>
    <FrontendSource>$(MSBuildThisFileDirectory)../frontend</FrontendSource>
    <WwwRoot>$(MSBuildThisFileDirectory)wwwroot</WwwRoot>
  </PropertyGroup>

  <Target Name="CopyFrontendToWwwRoot" BeforeTargets="Build;Publish">
    <ItemGroup>
      <_FrontendFiles Include="$(FrontendSource)\**\*" />
    </ItemGroup>
    <MakeDir Directories="$(WwwRoot)" />
    <Copy SourceFiles="@(_FrontendFiles)"
          DestinationFiles="@(_FrontendFiles->'$(WwwRoot)/%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <ItemGroup>
    <PackageReference Include="Dapper" Version="2.1.66" />
    <PackageReference Include="MySqlConnector" Version="2.5.0" />
  </ItemGroup>

</Project>
